<script>
// ══════════════════════════════
// AUDIO ENGINE (Web Audio API)
// ══════════════════════════════
const AC = new (window.AudioContext || window.webkitAudioContext)();
let soundOn = true;
document.getElementById('soundBtn').onclick = () => {
  soundOn = !soundOn;
  document.getElementById('soundBtn').textContent = soundOn ? '🔊' : '🔇';
};
function beep(freq=440, dur=0.08, type='square', vol=0.06, delay=0){
  if(!soundOn) return;
  try{
    const o=AC.createOscillator(), g=AC.createGain();
    o.connect(g);g.connect(AC.destination);
    o.type=type;o.frequency.value=freq;
    g.gain.setValueAtTime(vol,AC.currentTime+delay);
    g.gain.exponentialRampToValueAtTime(0.001,AC.currentTime+delay+dur);
    o.start(AC.currentTime+delay);o.stop(AC.currentTime+delay+dur+0.01);
  }catch(e){}
}
function glitchSound(){
  if(!soundOn) return;
  [0,0.05,0.1,0.15].forEach((d,i)=>{
    beep(80+Math.random()*400, 0.04, 'sawtooth', 0.04, d);
  });
}
function bootBeeps(){
  [440,550,660,880].forEach((f,i)=>beep(f,0.1,'square',0.05,i*0.12));
}
function loginHover(){
  beep(800,0.05,'sine',0.04);
  beep(1200,0.05,'sine',0.04,0.06);
}
function loginClick(){
  [220,330,440,660,880,1100].forEach((f,i)=>beep(f,0.1,'sine',0.06,i*0.06));
}

// ══════════════════════════════
// LOADER
// ══════════════════════════════
const steps=[
  "BOOTING KERNEL...","LOADING DRIVERS...","INIT NETWORK STACK...",
  "CONNECTING OAUTH SERVER...","VERIFYING CERTIFICATES...","SPAWNING ROBOT AI...",
  "CALIBRATING SENSORS...","MATRIX RAIN ENABLED...","GLOBE RENDERING...","SYSTEM READY."
];
let pct=0, step=0;
const bar=document.getElementById('loaderBar');
const txt=document.getElementById('loaderText');
const pctEl=document.getElementById('loaderPct');

function loaderTick(){
  if(pct>=100){
    setTimeout(()=>{
      document.getElementById('loader').classList.add('hide');
      document.getElementById('main').classList.add('show');
      initMatrix();initGlobe();bootBeeps();
      setTimeout(glitchSound,500);
    },400);
    return;
  }
  const inc=Math.random()<0.3?Math.floor(Math.random()*12)+1:Math.floor(Math.random()*4)+1;
  pct=Math.min(100,pct+inc);
  bar.style.width=pct+'%';
  pctEl.textContent=pct+'%';
  if(step<steps.length && pct>=step*(100/steps.length)){
    txt.textContent=steps[step++];
    beep(200+step*80,0.05,'square',0.03);
  }
  setTimeout(loaderTick, 40+Math.random()*80);
}
setTimeout(loaderTick,600);

// ══════════════════════════════
// MATRIX RAIN (HEAVY)
// ══════════════════════════════
function initMatrix(){
  const c=document.getElementById('matrix');
  const ctx=c.getContext('2d');
  c.width=window.innerWidth;c.height=window.innerHeight;
  const chars='アイウエオカキクケコサシスセソタチツテトナニヌネノハヒフヘホマミムメモヤユヨラリルレロワヲン0123456789ABCDEF<>{}[]';
  const cols=Math.floor(c.width/16);
  const drops=Array(cols).fill(1).map(()=>Math.random()*-100);
  const colors=['#00f5ff','#00ff88','#7b00ff','#ffffff'];

  function draw(){
    ctx.fillStyle='rgba(2,8,16,0.08)';
    ctx.fillRect(0,0,c.width,c.height);
    drops.forEach((y,i)=>{
      const ch=chars[Math.floor(Math.random()*chars.length)];
      const col=colors[Math.floor(Math.random()*colors.length)];
      const bright=Math.random()>0.92;
      ctx.fillStyle=bright?'#ffffff':col;
      ctx.font=(bright?'bold ':'')+'14px Share Tech Mono';
      ctx.globalAlpha=bright?1:0.4+Math.random()*0.4;
      ctx.fillText(ch,i*16,y*16);
      ctx.globalAlpha=1;
      if(y*16>c.height && Math.random()>0.975) drops[i]=0;
      drops[i]+=0.6+Math.random()*0.8;
    });
  }
  setInterval(draw,28);
  window.addEventListener('resize',()=>{c.width=window.innerWidth;c.height=window.innerHeight;});
}

// ══════════════════════════════
// 3D GLOBE
// ══════════════════════════════
function initGlobe(){
  const c=document.getElementById('globe');
  const ctx=c.getContext('2d');
  const W=220,H=220,R=90,cx=110,cy=110;
  let rot=0;

  // Lat/lon cities approx
  const points=[
    [51.5,-0.1],[40.7,-74],[35.6,139.7],[22.3,114.2],[28.6,77.2],
    [-33.9,18.4],[55.7,37.6],[48.8,2.3],[37.7,-122.4],[-23.5,-46.6],
    [10,77],[1.3,103.8],[31.2,121.5],[19.4,-99.1],[-34.6,-58.4],
    [6.5,3.4],[41.0,29.0],[59.9,30.3],[45.4,-75.7],[52.5,13.4]
  ];

  function latLonToXYZ(lat,lon,r){
    const phi=(90-lat)*Math.PI/180;
    const theta=(lon+rot)*Math.PI/180;
    return {
      x:r*Math.sin(phi)*Math.cos(theta),
      y:r*Math.cos(phi),
      z:r*Math.sin(phi)*Math.sin(theta)
    };
  }

  function drawGlobe(){
    ctx.clearRect(0,0,W,H);

    // Outer glow
    const grad=ctx.createRadialGradient(cx,cy,R-10,cx,cy,R+20);
    grad.addColorStop(0,'rgba(0,245,255,0.08)');
    grad.addColorStop(1,'transparent');
    ctx.fillStyle=grad;ctx.beginPath();ctx.arc(cx,cy,R+20,0,Math.PI*2);ctx.fill();

    // Globe base
    const base=ctx.createRadialGradient(cx-20,cy-20,10,cx,cy,R);
    base.addColorStop(0,'rgba(0,30,60,0.9)');
    base.addColorStop(1,'rgba(0,5,15,0.95)');
    ctx.fillStyle=base;ctx.beginPath();ctx.arc(cx,cy,R,0,Math.PI*2);ctx.fill();

    // Latitude lines
    for(let lat=-75;lat<=75;lat+=25){
      const y3d=R*Math.sin(lat*Math.PI/180);
      const r2d=Math.sqrt(R*R-y3d*y3d);
      const screenY=cy-y3d;
      ctx.beginPath();
      ctx.ellipse(cx,screenY,r2d,r2d*0.18,0,0,Math.PI*2);
      ctx.strokeStyle='rgba(0,245,255,0.12)';ctx.lineWidth=0.8;ctx.stroke();
    }

    // Longitude lines
    for(let lon=0;lon<180;lon+=30){
      ctx.beginPath();
      for(let lat=-90;lat<=90;lat+=5){
        const p=latLonToXYZ(lat,lon,R);
        const x2=cx+p.x,y2=cy-p.y;
        if(p.z>=0){lat===-90?ctx.moveTo(x2,y2):ctx.lineTo(x2,y2);}
        else{ctx.moveTo(x2,y2);}
      }
      ctx.strokeStyle='rgba(0,245,255,0.1)';ctx.lineWidth=0.8;ctx.stroke();
    }

    // City dots
    points.forEach(([lat,lon])=>{
      const p=latLonToXYZ(lat,lon,R);
      if(p.z<0) return;
      const x2=cx+p.x,y2=cy-p.y;
      const isSpecial=(Math.abs(lat-10)<5 && Math.abs(lon-77)<10);
      ctx.beginPath();
      ctx.arc(x2,y2,isSpecial?4:2,0,Math.PI*2);
      ctx.fillStyle=isSpecial?'#00ff88':'rgba(0,245,255,0.8)';
      ctx.fill();
      if(isSpecial){
        ctx.beginPath();ctx.arc(x2,y2,7,0,Math.PI*2);
        ctx.strokeStyle='rgba(0,255,136,0.5)';ctx.lineWidth=1;ctx.stroke();
      }
    });

    // Border ring
    ctx.beginPath();ctx.arc(cx,cy,R,0,Math.PI*2);
    ctx.strokeStyle='rgba(0,245,255,0.5)';ctx.lineWidth=1.5;ctx.stroke();

    // Shine
    const shine=ctx.createRadialGradient(cx-30,cy-30,5,cx-20,cy-25,60);
    shine.addColorStop(0,'rgba(255,255,255,0.06)');
    shine.addColorStop(1,'transparent');
    ctx.fillStyle=shine;ctx.beginPath();ctx.arc(cx,cy,R,0,Math.PI*2);ctx.fill();

    // Label
    ctx.fillStyle='rgba(0,245,255,0.4)';
    ctx.font='9px Share Tech Mono';
    ctx.textAlign='center';
    ctx.fillText('GLOBAL NETWORK',cx,cy+R+14);

    rot+=0.4;
    requestAnimationFrame(drawGlobe);
  }
  drawGlobe();
}

// ══════════════════════════════
// HUD COUNTERS
// ══════════════════════════════
function updateClock(){
  const n=new Date();
  document.getElementById('clock').textContent=
    String(n.getHours()).padStart(2,'0')+':'+
    String(n.getMinutes()).padStart(2,'0')+':'+
    String(n.getSeconds()).padStart(2,'0');
}
setInterval(updateClock,1000);updateClock();

document.getElementById('nodeid').textContent=
  Math.floor(Math.random()*0xFFFF).toString(16).toUpperCase().padStart(4,'0');

let uc=0,tgt=Math.floor(Math.random()*600)+300;
const uci=setInterval(()=>{
  uc+=Math.ceil(tgt/50);
  if(uc>=tgt){uc=tgt;clearInterval(uci);}
  document.getElementById('ucnt').textContent=uc;
},35);

let sec=0;
setInterval(()=>{
  sec++;
  const h=String(Math.floor(sec/3600)).padStart(2,'0');
  const m=String(Math.floor((sec%3600)/60)).padStart(2,'0');
  const s=String(sec%60).padStart(2,'0');
  document.getElementById('uptime').textContent=h+':'+m+':'+s;
  document.getElementById('uphex').textContent=sec.toString(16).toUpperCase().padStart(6,'0');
},1000);

// ══════════════════════════════
// BUTTON SOUNDS
// ══════════════════════════════
const btn=document.getElementById('loginBtn');
btn.addEventListener('mouseenter',()=>{ if(AC.state==='suspended')AC.resume(); loginHover(); });
btn.addEventListener('click',(e)=>{ e.preventDefault(); loginClick(); glitchSound(); setTimeout(()=>window.location.href='/auth/google',500); });

// Random glitch sounds
setInterval(()=>{ if(Math.random()<0.15) glitchSound(); },8000);
</script>
